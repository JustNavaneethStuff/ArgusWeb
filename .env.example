# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_MAX_IN_FLIGHT=10

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=argus
MINIO_SECRET_KEY=argussecret
MINIO_BUCKET=argus-html
MINIO_SECURE=false

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=argus

# Crawler
CRAWLER_CONCURRENCY=10
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_USER_AGENT=ArgusBot/0.1 (+https://github.com/argus)
CRAWLER_PROXY_URLS=

# Rate limiting
RATE_LIMIT_TOKENS_PER_SECOND=1.0
RATE_LIMIT_BURST=5

# Retry
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SECONDS=1.0

# Incremental crawl
INCREMENTAL_RECRAWL_TTL_SECONDS=3600
DLQ_MAX_REPLAYS=3

# Search
SEARCH_SIMILARITY_THRESHOLD=0.1
SEARCH_DEFAULT_LIMIT=20
SEARCH_MAX_LIMIT=100

# API
API_HOST=0.0.0.0
API_PORT=8000
