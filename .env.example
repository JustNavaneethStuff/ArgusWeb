# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=argus
MINIO_SECRET_KEY=argussecret
MINIO_BUCKET=argus-html
MINIO_SECURE=false

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=argus

# Crawler
CRAWLER_CONCURRENCY=10
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_USER_AGENT=ArgusBot/0.1 (+https://github.com/argus)

# API
API_HOST=0.0.0.0
API_PORT=8000
